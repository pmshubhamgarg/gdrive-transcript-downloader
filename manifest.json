{
  "manifest_version": 3,
  "name": "Google Drive Transcript Downloader",
  "version": "1.0",
  "description": "Automatically opens transcript and lets you download it from Google Drive videos",
  "permissions": [
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "https://drive.google.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://drive.google.com/*"],
      "js": ["interceptor.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": ["https://drive.google.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
